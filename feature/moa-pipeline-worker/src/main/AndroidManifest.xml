<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Foreground service permission for InferenceService -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <application>
        <!-- Custom Inference Service with specialUse foreground type -->
        <!-- specialUse has no quota limits (unlike dataSync which has 6-hour limit on Android 15+) -->
        <service
            android:name=".service.InferenceService"
            android:foregroundServiceType="specialUse"
            android:exported="false">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="on-device AI inference for generating chat responses"/>
        </service>
    </application>

</manifest>
